{
  "name": "sunrise-ged",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.8",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "astro check && astro build",
    "preview": "wrangler pages dev dist",
    "worker:dev": "wrangler dev worker/index.ts",
    "db:migrate": "wrangler d1 execute sunrise-ged-db --file=worker/db/schema.sql",
    "db:seed": "wrangler d1 execute sunrise-ged-db --file=worker/db/seed.sql",
    "check": "astro check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^11.2.0",
    "@astrojs/react": "^3.6.2",
    "@astrojs/tailwind": "^5.1.2",
    "@hono/zod-validator": "^0.4.3",
    "@splidejs/splide": "^4.1.4",
    "@vitejs/plugin-react": "^4.3.4",
    "astro": "^4.16.18",
    "bcryptjs": "^2.4.3",
    "hono": "^4.6.15",
    "jose": "^5.9.6",
    "otpauth": "^9.4.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.1",
    "tailwindcss": "^3.4.17",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@cloudflare/workers-types": "^4.20241230.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.10",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0"
  }
}
