---
import type { Locale } from '../lib/i18n';
import { pathFor } from '../lib/i18n';
const { locale, label } = Astro.props as { locale: Locale; label: string };
const languages: { code: Locale; name: string }[] = [
  { code: 'en', name: 'EN' },
  { code: 'my', name: 'မြန်မာ' },
  { code: 'th', name: 'ไทย' }
];
---
<label class="sr-only" for="language-switcher">{label}</label>
<select
  id="language-switcher"
  class="rounded-md border border-white/15 bg-site-dark px-3 py-2 text-sm text-white outline-none transition focus:border-gold"
  aria-label={label}
>
  {languages.map((lang) => <option value={pathFor(lang.code, Astro.url.pathname)} selected={locale === lang.code}>{lang.name}</option>)}
</select>
<script>
  const switcher = document.getElementById('language-switcher');
  switcher?.addEventListener('change', (event) => {
    const value = event.target instanceof HTMLSelectElement ? event.target.value : '/';
    window.location.href = value;
  });
</script>
