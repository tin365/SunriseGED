---
const links = [
  ['/admin', 'Dashboard'],
  ['/admin/posts', 'Posts'],
  ['/admin/enrollments', 'Enrollments'],
  ['/admin/media', 'Media'],
  ['/admin/users', 'Users'],
  ['/admin/settings', 'Settings']
];
---
<aside class="border-b border-white/10 bg-site-dark p-4 lg:min-h-screen lg:w-72 lg:border-b-0 lg:border-r">
  <a href="/admin" class="flex items-center gap-3">
    <img src="/logo.png" alt="Sunrise GED" class="h-12 w-12 rounded-full" />
    <span class="font-heading text-xl font-bold text-gold">Sunrise Admin</span>
  </a>
  <nav class="mt-8 grid gap-2">
    {links.map(([href, label]) => <a href={href} class="rounded-md px-3 py-3 text-sm font-semibold text-white/75 hover:bg-white/5 hover:text-gold">{label}</a>)}
  </nav>
</aside>
