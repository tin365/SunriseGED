---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EnrollmentForm from '../EnrollmentForm';
import { t, type Locale } from '../../lib/i18n';
const { locale = 'en' } = Astro.props as { locale: Locale };
const dict = t(locale);
---
<BaseLayout title={dict.enroll.title} description={dict.enroll.subtitle}>
  <section class="bg-site-black px-4 pb-12 pt-32 sm:px-6 lg:px-8"><div class="mx-auto max-w-5xl"><h1 class="font-heading text-5xl font-bold text-gold">{dict.enroll.title}</h1><p class="mt-5 text-lg text-white/75">{dict.enroll.subtitle}</p></div></section>
  <section class="section-pad bg-site-black pt-0">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1fr_420px]">
      <EnrollmentForm dict={dict} locale={locale} client:load />
      <aside class="space-y-5">
        <div class="rounded-2xl border border-white/10 bg-site-dark p-6"><h2 class="font-heading text-2xl font-bold text-gold">What happens next</h2><ol class="mt-4 space-y-3 text-sm leading-6 text-white/75"><li>1. Application review within 3-5 business days.</li><li>2. Family contact and short interview.</li><li>3. Placement guidance and orientation.</li></ol></div>
        <div class="rounded-2xl border border-white/10 bg-site-dark p-6"><h2 class="font-heading text-2xl font-bold text-gold">Questions</h2><details class="mt-4 border-t border-white/10 py-3"><summary class="cursor-pointer font-semibold">Is there a fee?</summary><p class="mt-2 text-sm text-white/70">Sunrise prioritizes access for refugee families. Contact the team for current support details.</p></details><details class="border-t border-white/10 py-3"><summary class="cursor-pointer font-semibold">Who can apply?</summary><p class="mt-2 text-sm text-white/70">Myanmar youth in the Mae Sot area who need GED preparation and support.</p></details><details class="border-t border-white/10 py-3"><summary class="cursor-pointer font-semibold">What is the schedule?</summary><p class="mt-2 text-sm text-white/70">Class schedules are shared during admissions based on the current cohort.</p></details></div>
      </aside>
    </div>
  </section>
</BaseLayout>
