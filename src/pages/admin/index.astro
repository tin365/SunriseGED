---
import AdminLayout from '../../layouts/AdminLayout.astro';
export const prerender = false;
---
<AdminLayout title="Dashboard">
  <h1 class="font-heading text-4xl font-bold text-gold">Dashboard</h1>
  <div class="mt-8 grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
    {['Total Enrollments', 'Pending Review', 'Published Posts', 'Total Media'].map((label, index) => <article class="rounded-2xl border border-white/10 bg-site-dark p-5"><p class="text-sm text-white/60">{label}</p><p class="mt-3 font-heading text-4xl font-bold text-gold">{index === 1 ? '0' : '-'}</p></article>)}
  </div>
  <div class="mt-8 grid gap-5 xl:grid-cols-2">
    <section class="rounded-2xl border border-white/10 bg-site-dark p-5"><h2 class="font-heading text-2xl font-bold text-gold">Recent Enrollments</h2><p class="mt-4 text-white/60">Enrollment data loads from the protected API after login.</p></section>
    <section class="rounded-2xl border border-white/10 bg-site-dark p-5"><h2 class="font-heading text-2xl font-bold text-gold">Recent Activity</h2><p class="mt-4 text-white/60">Audit log records admin actions, login events, and content changes.</p></section>
  </div>
  <div class="mt-8 flex flex-wrap gap-3"><a class="rounded-md bg-gold px-5 py-3 font-bold text-site-black" href="/admin/posts">New Post</a><a class="rounded-md border border-gold px-5 py-3 font-bold text-gold" href="/admin/enrollments">Review Enrollments</a><a class="rounded-md border border-gold px-5 py-3 font-bold text-gold" href="/admin/media">Upload Media</a></div>
</AdminLayout>
