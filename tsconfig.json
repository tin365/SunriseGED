{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "types": ["@cloudflare/workers-types"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@worker/*": ["worker/*"]
    }
  },
  "include": [".astro/types.d.ts", "src/**/*", "worker/**/*"]
}
